<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#23272A">

    <!-- ══ Browser Section (top 52%) ══════════════════════════════════════════ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="52"
        android:orientation="vertical"
        android:background="#2C2F33">

        <!-- Browser header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="#5865F2"
            android:gravity="center_vertical"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="5dp"
            android:paddingBottom="5dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/label_browser"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/tvStats"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0✓ 0✗"
                android:textColor="#B0E0FF"
                android:textSize="10sp"
                android:layout_marginEnd="8dp" />

            <TextView
                android:id="@+id/tvStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="● Ready"
                android:textColor="#FFFFFF"
                android:textSize="11sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- URL navigation bar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="38dp"
            android:orientation="horizontal"
            android:background="#23272A"
            android:gravity="center_vertical"
            android:paddingStart="6dp"
            android:paddingEnd="6dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp">

            <EditText
                android:id="@+id/etUrl"
                android:layout_width="0dp"
                android:layout_height="30dp"
                android:layout_weight="1"
                android:hint="@string/hint_url"
                android:inputType="textUri"
                android:textSize="11sp"
                android:textColor="#DCDDDE"
                android:textColorHint="#72767D"
                android:background="@drawable/bg_input"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:maxLines="1"
                android:layout_marginEnd="6dp" />

            <Button
                android:id="@+id/btnGo"
                android:layout_width="52dp"
                android:layout_height="30dp"
                android:text="GO"
                android:textSize="10sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:backgroundTint="#5865F2"
                android:padding="0dp" />
        </LinearLayout>

        <!-- WebView -->
        <WebView
            android:id="@+id/webView"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />
    </LinearLayout>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="3dp"
        android:background="#5865F2" />

    <!-- ══ Control Panel (bottom 48%) ═════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/terminalPanel"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="48"
        android:orientation="vertical"
        android:background="#1E2124">

        <!-- Panel header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="#2C2F33"
            android:gravity="center_vertical"
            android:paddingTop="3dp"
            android:paddingBottom="3dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/label_terminal"
                android:textColor="#DCDDDE"
                android:textStyle="bold"
                android:textSize="12sp"
                android:paddingStart="10dp"
                android:paddingTop="3dp"
                android:paddingBottom="3dp" />

            <TextView
                android:id="@+id/tvDisclaimer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/disclaimer"
                android:textColor="#FAA61A"
                android:textSize="9sp"
                android:paddingEnd="6dp" />

            <Button
                android:id="@+id/btnClearLog"
                android:layout_width="wrap_content"
                android:layout_height="28dp"
                android:text="Clear"
                android:textSize="9sp"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:backgroundTint="#4F545C"
                android:textColor="#DCDDDE"
                android:layout_marginEnd="6dp" />
        </LinearLayout>

        <!-- Input fields card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="6dp"
            android:paddingBottom="5dp"
            android:background="#2C2F33">

            <!-- Row 1: Gmail + Count -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="5dp">

                <EditText
                    android:id="@+id/etGmail"
                    android:layout_width="0dp"
                    android:layout_height="36dp"
                    android:layout_weight="3"
                    android:hint="@string/hint_gmail"
                    android:inputType="textEmailAddress"
                    android:textSize="11sp"
                    android:textColor="#DCDDDE"
                    android:textColorHint="#72767D"
                    android:background="@drawable/bg_input"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    android:layout_marginEnd="6dp"
                    android:maxLines="1" />

                <EditText
                    android:id="@+id/etCount"
                    android:layout_width="0dp"
                    android:layout_height="36dp"
                    android:layout_weight="1"
                    android:hint="Count"
                    android:inputType="number"
                    android:textSize="11sp"
                    android:textColor="#DCDDDE"
                    android:textColorHint="#72767D"
                    android:background="@drawable/bg_input"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    android:gravity="center"
                    android:maxLines="1" />
            </LinearLayout>

            <!-- Row 2: Password + Start -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="5dp">

                <EditText
                    android:id="@+id/etPassword"
                    android:layout_width="0dp"
                    android:layout_height="36dp"
                    android:layout_weight="1"
                    android:hint="@string/hint_password"
                    android:inputType="textPassword"
                    android:textSize="11sp"
                    android:textColor="#DCDDDE"
                    android:textColorHint="#72767D"
                    android:background="@drawable/bg_input"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    android:layout_marginEnd="6dp"
                    android:maxLines="1" />

                <Button
                    android:id="@+id/btnStart"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:text="@string/btn_start"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textColor="#000000"
                    android:backgroundTint="#57F287"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp" />
            </LinearLayout>

            <!-- Row 3: Groq API Key + Test -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="5dp">

                <EditText
                    android:id="@+id/etGroqKey"
                    android:layout_width="0dp"
                    android:layout_height="32dp"
                    android:layout_weight="1"
                    android:hint="@string/hint_groq_key"
                    android:inputType="textVisiblePassword"
                    android:textSize="10sp"
                    android:textColor="#DCDDDE"
                    android:textColorHint="#72767D"
                    android:background="@drawable/bg_input"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    android:layout_marginEnd="6dp"
                    android:maxLines="1" />

                <Button
                    android:id="@+id/btnTestGroq"
                    android:layout_width="wrap_content"
                    android:layout_height="32dp"
                    android:text="@string/btn_test_groq"
                    android:textSize="9sp"
                    android:textColor="#FFFFFF"
                    android:backgroundTint="#FAA61A"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp" />
            </LinearLayout>

            <!-- Row 4: CAPTCHA solvers (no API key required) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btnSolveCaptcha"
                    android:layout_width="0dp"
                    android:layout_height="30dp"
                    android:layout_weight="1"
                    android:text="@string/btn_solve_captcha"
                    android:textSize="7.5sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:backgroundTint="#7289DA"
                    android:layout_marginEnd="3dp"
                    android:padding="0dp" />

                <Button
                    android:id="@+id/btnLocalSolve"
                    android:layout_width="0dp"
                    android:layout_height="30dp"
                    android:layout_weight="1"
                    android:text="@string/btn_local_solve"
                    android:textSize="7.5sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:backgroundTint="#ED4245"
                    android:layout_marginEnd="3dp"
                    android:padding="0dp" />

                <Button
                    android:id="@+id/btnAccessibility"
                    android:layout_width="0dp"
                    android:layout_height="30dp"
                    android:layout_weight="1"
                    android:text="@string/btn_accessibility"
                    android:textSize="7.5sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:backgroundTint="#7289DA"
                    android:layout_marginEnd="3dp"
                    android:padding="0dp" />

                <Button
                    android:id="@+id/btnClickRegister"
                    android:layout_width="0dp"
                    android:layout_height="30dp"
                    android:layout_weight="1"
                    android:text="@string/btn_click_register"
                    android:textSize="7.5sp"
                    android:textStyle="bold"
                    android:textColor="#000000"
                    android:backgroundTint="#43B581"
                    android:padding="0dp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Download / file buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:background="#23272A">

            <Button
                android:id="@+id/btnDownloadAcc"
                android:layout_width="0dp"
                android:layout_height="30dp"
                android:layout_weight="1"
                android:text="@string/btn_download_acc"
                android:textSize="9sp"
                android:textColor="#FFFFFF"
                android:backgroundTint="#5865F2"
                android:enabled="false"
                android:layout_marginEnd="5dp" />

            <Button
                android:id="@+id/btnDownloadTokens"
                android:layout_width="0dp"
                android:layout_height="30dp"
                android:layout_weight="1"
                android:text="@string/btn_download_tokens"
                android:textSize="9sp"
                android:textColor="#FFFFFF"
                android:backgroundTint="#5865F2"
                android:enabled="false"
                android:layout_marginEnd="5dp" />

            <Button
                android:id="@+id/btnOpenFile"
                android:layout_width="0dp"
                android:layout_height="30dp"
                android:layout_weight="1"
                android:text="Files"
                android:textSize="9sp"
                android:textColor="#FFFFFF"
                android:backgroundTint="#4F545C" />
        </LinearLayout>

        <!-- Terminal log output (auto-scrolling) -->
        <ScrollView
            android:id="@+id/scrollLog"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:background="#1E2124"
            android:fillViewport="true">

            <TextView
                android:id="@+id/tvLog"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="monospace"
                android:textColor="#57F287"
                android:textSize="10sp"
                android:background="#1E2124"
                android:padding="8dp"
                android:text="[Discord Creator v2 - Educational Tool]\n[Enter Gmail, password, and optionally a Groq API key, then tap Start.]\n[Local Solver: advanced hCaptcha bypass — no API key needed]\n" />
        </ScrollView>
    </LinearLayout>

</LinearLayout>
