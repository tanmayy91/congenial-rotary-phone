<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#23272A">

    <!-- ══ Browser Section (top 50%) ══════════════════════════════════════════ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="50"
        android:orientation="vertical"
        android:background="#2C2F33">

        <!-- Browser header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="#5865F2"
            android:gravity="center_vertical"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/label_browser"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/tvStats"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0✓ 0✗"
                android:textColor="#B0E0FF"
                android:textSize="10sp"
                android:layout_marginEnd="8dp" />

            <TextView
                android:id="@+id/tvStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="● Ready"
                android:textColor="#FFFFFF"
                android:textSize="11sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- URL navigation bar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="36dp"
            android:orientation="horizontal"
            android:background="#23272A"
            android:gravity="center_vertical"
            android:paddingStart="6dp"
            android:paddingEnd="6dp"
            android:paddingTop="3dp"
            android:paddingBottom="3dp">

            <EditText
                android:id="@+id/etUrl"
                android:layout_width="0dp"
                android:layout_height="29dp"
                android:layout_weight="1"
                android:hint="@string/hint_url"
                android:inputType="textUri"
                android:textSize="10sp"
                android:textColor="#DCDDDE"
                android:textColorHint="#72767D"
                android:background="@drawable/bg_input"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:maxLines="1"
                android:layout_marginEnd="5dp" />

            <Button
                android:id="@+id/btnGo"
                android:layout_width="48dp"
                android:layout_height="29dp"
                android:text="GO"
                android:textSize="9sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:backgroundTint="#5865F2"
                android:padding="0dp" />
        </LinearLayout>

        <!-- WebView -->
        <WebView
            android:id="@+id/webView"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />
    </LinearLayout>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="3dp"
        android:background="#5865F2" />

    <!-- ══ Control Panel (bottom 50%) ═════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/terminalPanel"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="50"
        android:orientation="vertical"
        android:background="#1E2124">

        <!-- Panel header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="#2C2F33"
            android:gravity="center_vertical"
            android:paddingTop="2dp"
            android:paddingBottom="2dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/label_terminal"
                android:textColor="#DCDDDE"
                android:textStyle="bold"
                android:textSize="11sp"
                android:paddingStart="10dp" />

            <TextView
                android:id="@+id/tvDisclaimer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/disclaimer"
                android:textColor="#FAA61A"
                android:textSize="9sp"
                android:paddingEnd="6dp" />

            <Button
                android:id="@+id/btnClearLog"
                android:layout_width="wrap_content"
                android:layout_height="26dp"
                android:text="Clear"
                android:textSize="8sp"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:backgroundTint="#4F545C"
                android:textColor="#DCDDDE"
                android:layout_marginEnd="5dp" />
        </LinearLayout>

        <!-- ── Mode toggle row ────────────────────────────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="32dp"
            android:orientation="horizontal"
            android:background="#1A1C1F"
            android:paddingStart="6dp"
            android:paddingEnd="6dp"
            android:paddingTop="3dp"
            android:paddingBottom="3dp"
            android:gravity="center_vertical">

            <Button
                android:id="@+id/btnModeBrowser"
                android:layout_width="0dp"
                android:layout_height="26dp"
                android:layout_weight="1"
                android:text="◉ BROWSER"
                android:textSize="8.5sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:backgroundTint="#5865F2"
                android:layout_marginEnd="3dp"
                android:padding="0dp" />

            <Button
                android:id="@+id/btnModeReq"
                android:layout_width="0dp"
                android:layout_height="26dp"
                android:layout_weight="1"
                android:text="◯ REQUEST"
                android:textSize="8.5sp"
                android:textStyle="bold"
                android:textColor="#888888"
                android:backgroundTint="#2C2F33"
                android:layout_marginEnd="3dp"
                android:padding="0dp" />

            <Button
                android:id="@+id/btnModeChrome"
                android:layout_width="0dp"
                android:layout_height="26dp"
                android:layout_weight="1"
                android:text="◯ CHROME"
                android:textSize="8.5sp"
                android:textStyle="bold"
                android:textColor="#888888"
                android:backgroundTint="#2C2F33"
                android:padding="0dp" />
        </LinearLayout>

        <!-- Input fields card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="7dp"
            android:paddingEnd="7dp"
            android:paddingTop="5dp"
            android:paddingBottom="3dp"
            android:background="#2C2F33">

            <!-- Row 1: Email + Count -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="4dp">

                <EditText
                    android:id="@+id/etGmail"
                    android:layout_width="0dp"
                    android:layout_height="34dp"
                    android:layout_weight="3"
                    android:hint="@string/hint_gmail"
                    android:inputType="textEmailAddress"
                    android:textSize="10.5sp"
                    android:textColor="#DCDDDE"
                    android:textColorHint="#72767D"
                    android:background="@drawable/bg_input"
                    android:paddingStart="9dp"
                    android:paddingEnd="9dp"
                    android:layout_marginEnd="5dp"
                    android:maxLines="1" />

                <EditText
                    android:id="@+id/etCount"
                    android:layout_width="0dp"
                    android:layout_height="34dp"
                    android:layout_weight="1"
                    android:hint="Count"
                    android:inputType="number"
                    android:textSize="11sp"
                    android:textColor="#DCDDDE"
                    android:textColorHint="#72767D"
                    android:background="@drawable/bg_input"
                    android:paddingStart="9dp"
                    android:paddingEnd="9dp"
                    android:gravity="center"
                    android:maxLines="1" />
            </LinearLayout>

            <!-- Row 2: Password + Start -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="4dp">

                <EditText
                    android:id="@+id/etPassword"
                    android:layout_width="0dp"
                    android:layout_height="34dp"
                    android:layout_weight="1"
                    android:hint="@string/hint_password"
                    android:inputType="textPassword"
                    android:textSize="10.5sp"
                    android:textColor="#DCDDDE"
                    android:textColorHint="#72767D"
                    android:background="@drawable/bg_input"
                    android:paddingStart="9dp"
                    android:paddingEnd="9dp"
                    android:layout_marginEnd="5dp"
                    android:maxLines="1" />

                <Button
                    android:id="@+id/btnStart"
                    android:layout_width="wrap_content"
                    android:layout_height="34dp"
                    android:text="@string/btn_start"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textColor="#000000"
                    android:backgroundTint="#57F287"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp" />
            </LinearLayout>

            <!-- Row 3: Groq API Key + Test -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="4dp">

                <EditText
                    android:id="@+id/etGroqKey"
                    android:layout_width="0dp"
                    android:layout_height="30dp"
                    android:layout_weight="1"
                    android:hint="@string/hint_groq_key"
                    android:inputType="textVisiblePassword"
                    android:textSize="9.5sp"
                    android:textColor="#DCDDDE"
                    android:textColorHint="#72767D"
                    android:background="@drawable/bg_input"
                    android:paddingStart="9dp"
                    android:paddingEnd="9dp"
                    android:layout_marginEnd="5dp"
                    android:maxLines="1" />

                <Button
                    android:id="@+id/btnTestGroq"
                    android:layout_width="wrap_content"
                    android:layout_height="30dp"
                    android:text="@string/btn_test_groq"
                    android:textSize="8.5sp"
                    android:textColor="#FFFFFF"
                    android:backgroundTint="#FAA61A"
                    android:paddingStart="9dp"
                    android:paddingEnd="9dp" />
            </LinearLayout>

            <!-- ══ BROWSER mode row ══════════════════════════════════════════ -->
            <LinearLayout
                android:id="@+id/rowBrowserCaptcha"
                android:layout_width="match_parent"
                android:layout_height="28dp"
                android:orientation="horizontal"
                android:visibility="visible">

                <Button
                    android:id="@+id/btnSolveCaptcha"
                    android:layout_width="0dp"
                    android:layout_height="28dp"
                    android:layout_weight="1"
                    android:text="@string/btn_solve_captcha"
                    android:textSize="7sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:backgroundTint="#7289DA"
                    android:layout_marginEnd="2dp"
                    android:padding="0dp" />

                <Button
                    android:id="@+id/btnLocalSolve"
                    android:layout_width="0dp"
                    android:layout_height="28dp"
                    android:layout_weight="1"
                    android:text="@string/btn_local_solve"
                    android:textSize="7sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:backgroundTint="#ED4245"
                    android:layout_marginEnd="2dp"
                    android:padding="0dp" />

                <Button
                    android:id="@+id/btnAccessibility"
                    android:layout_width="0dp"
                    android:layout_height="28dp"
                    android:layout_weight="1"
                    android:text="@string/btn_accessibility"
                    android:textSize="7sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:backgroundTint="#7289DA"
                    android:layout_marginEnd="2dp"
                    android:padding="0dp" />

                <Button
                    android:id="@+id/btnClickRegister"
                    android:layout_width="0dp"
                    android:layout_height="28dp"
                    android:layout_weight="1"
                    android:text="@string/btn_click_register"
                    android:textSize="7sp"
                    android:textStyle="bold"
                    android:textColor="#000000"
                    android:backgroundTint="#43B581"
                    android:padding="0dp" />
            </LinearLayout>

            <!-- ══ REQUEST mode row ══════════════════════════════════════════ -->
            <LinearLayout
                android:id="@+id/rowReqInfo"
                android:layout_width="match_parent"
                android:layout_height="28dp"
                android:orientation="horizontal"
                android:visibility="gone"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="⚡ Direct API — CAPTCHA dialog on demand"
                    android:textColor="#57F287"
                    android:textSize="8.5sp"
                    android:fontFamily="monospace" />

                <Button
                    android:id="@+id/btnOpenCaptchaManual"
                    android:layout_width="wrap_content"
                    android:layout_height="26dp"
                    android:text="Manual CAPTCHA"
                    android:textSize="7.5sp"
                    android:textColor="#FFFFFF"
                    android:backgroundTint="#ED4245"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp"
                    android:padding="0dp" />
            </LinearLayout>

            <!-- ══ CHROME mode row ═══════════════════════════════════════════ -->
            <LinearLayout
                android:id="@+id/rowChromeButtons"
                android:layout_width="match_parent"
                android:layout_height="28dp"
                android:orientation="horizontal"
                android:visibility="gone">

                <Button
                    android:id="@+id/btnChromeOpen"
                    android:layout_width="0dp"
                    android:layout_height="28dp"
                    android:layout_weight="1"
                    android:text="Open Chrome"
                    android:textSize="7sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:backgroundTint="#4285F4"
                    android:layout_marginEnd="2dp"
                    android:padding="0dp" />

                <Button
                    android:id="@+id/btnChromeGmail"
                    android:layout_width="0dp"
                    android:layout_height="28dp"
                    android:layout_weight="1"
                    android:text="Open Gmail"
                    android:textSize="7sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:backgroundTint="#EA4335"
                    android:layout_marginEnd="2dp"
                    android:padding="0dp" />

                <Button
                    android:id="@+id/btnChromeCopy"
                    android:layout_width="0dp"
                    android:layout_height="28dp"
                    android:layout_weight="1"
                    android:text="Copy Data"
                    android:textSize="7sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:backgroundTint="#FAA61A"
                    android:layout_marginEnd="2dp"
                    android:padding="0dp" />

                <Button
                    android:id="@+id/btnChromeToken"
                    android:layout_width="0dp"
                    android:layout_height="28dp"
                    android:layout_weight="1"
                    android:text="Enter Token"
                    android:textSize="7sp"
                    android:textStyle="bold"
                    android:textColor="#000000"
                    android:backgroundTint="#57F287"
                    android:padding="0dp" />
            </LinearLayout>

        </LinearLayout>

        <!-- Download / file buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="7dp"
            android:paddingEnd="7dp"
            android:paddingTop="3dp"
            android:paddingBottom="3dp"
            android:background="#23272A">

            <Button
                android:id="@+id/btnDownloadAcc"
                android:layout_width="0dp"
                android:layout_height="28dp"
                android:layout_weight="1"
                android:text="@string/btn_download_acc"
                android:textSize="8.5sp"
                android:textColor="#FFFFFF"
                android:backgroundTint="#5865F2"
                android:enabled="false"
                android:layout_marginEnd="4dp" />

            <Button
                android:id="@+id/btnDownloadTokens"
                android:layout_width="0dp"
                android:layout_height="28dp"
                android:layout_weight="1"
                android:text="@string/btn_download_tokens"
                android:textSize="8.5sp"
                android:textColor="#FFFFFF"
                android:backgroundTint="#5865F2"
                android:enabled="false"
                android:layout_marginEnd="4dp" />

            <Button
                android:id="@+id/btnOpenFile"
                android:layout_width="0dp"
                android:layout_height="28dp"
                android:layout_weight="1"
                android:text="Files"
                android:textSize="8.5sp"
                android:textColor="#FFFFFF"
                android:backgroundTint="#4F545C" />
        </LinearLayout>

        <!-- Terminal log (auto-scrolling) -->
        <ScrollView
            android:id="@+id/scrollLog"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:background="#1E2124"
            android:fillViewport="true">

            <TextView
                android:id="@+id/tvLog"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="monospace"
                android:textColor="#57F287"
                android:textSize="9.5sp"
                android:background="#1E2124"
                android:padding="7dp"
                android:text="[Discord Creator v3]\n[BROWSER — WebView automation]\n[REQUEST — Direct API + on-demand CAPTCHA]\n[CHROME  — Real Chrome + guided manual flow]\n" />
        </ScrollView>
    </LinearLayout>

</LinearLayout>
